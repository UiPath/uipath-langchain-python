@prefix sh:  <http://www.w3.org/ns/shacl#> .
@prefix ont: <https://ontology.uipath.com/ont#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ont:SupplierShape a sh:NodeShape ; sh:targetClass ont:Supplier ; rdfs:label "Supplier" .
ont:InvoiceShape a sh:NodeShape ; sh:targetClass ont:Invoice ; rdfs:label "Invoice" .
ont:CommodityShape a sh:NodeShape ; sh:targetClass ont:Commodity ; rdfs:label "Commodity" .
ont:SpendRecordShape a sh:NodeShape ; sh:targetClass ont:SpendRecord ; rdfs:label "SpendRecord" .
ont:FXRateShape a sh:NodeShape ; sh:targetClass ont:FXRate ; rdfs:label "FXRate" .
ont:PurchaseOrderShape a sh:NodeShape ; sh:targetClass ont:PurchaseOrder ; rdfs:label "PurchaseOrder" .
ont:ToleranceExceptionShape a sh:NodeShape ; sh:targetClass ont:ToleranceException ; rdfs:label "ToleranceException" .
