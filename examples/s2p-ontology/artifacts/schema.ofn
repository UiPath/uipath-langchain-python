Declaration(DataProperty(:SpendRecord.normalizedAmount))
Declaration(DataProperty(:SpendRecord.period))
Declaration(DataProperty(:SpendRecord.onContract))


############################
#   Object Properties
############################

# Supplier hierarchy
AnnotationAssertion(rdfs:label :supplier_hasParent "has parent supplier")
ObjectPropertyDomain(:supplier_hasParent :Supplier)
ObjectPropertyRange(:supplier_hasParent :Supplier)

# Commodity hierarchy
AnnotationAssertion(rdfs:label :commodity_partOf "part of")
ObjectPropertyDomain(:commodity_partOf :Commodity)
ObjectPropertyRange(:commodity_partOf :Commodity)

# Invoice → Supplier
AnnotationAssertion(rdfs:label :invoice_paidTo "paid to")
ObjectPropertyDomain(:invoice_paidTo :Invoice)
ObjectPropertyRange(:invoice_paidTo :Supplier)

# Invoice → PurchaseOrder
AnnotationAssertion(rdfs:label :invoice_referencesPO "references PO")
ObjectPropertyDomain(:invoice_referencesPO :Invoice)
ObjectPropertyRange(:invoice_referencesPO :PurchaseOrder)

# PurchaseOrder → Supplier
AnnotationAssertion(rdfs:label :po_orderedFrom "ordered from")
ObjectPropertyDomain(:po_orderedFrom :PurchaseOrder)
ObjectPropertyRange(:po_orderedFrom :Supplier)

# Item → Commodity
AnnotationAssertion(rdfs:label :item_classifiedAs "classified as")
ObjectPropertyDomain(:item_classifiedAs :Item)
ObjectPropertyRange(:item_classifiedAs :Commodity)

# Item → Requisition
AnnotationAssertion(rdfs:label :item_onRequisition "on requisition")
ObjectPropertyDomain(:item_onRequisition :Item)
ObjectPropertyRange(:item_onRequisition :Requisition)

# Item → PurchaseOrder
AnnotationAssertion(rdfs:label :item_onPO "on PO")
ObjectPropertyDomain(:item_onPO :Item)
ObjectPropertyRange(:item_onPO :PurchaseOrder)

# Item → Invoice
AnnotationAssertion(rdfs:label :item_onInvoice "on invoice")
ObjectPropertyDomain(:item_onInvoice :Item)
ObjectPropertyRange(:item_onInvoice :Invoice)

# Contract → Supplier
AnnotationAssertion(rdfs:label :contract_suppliedBy "supplied by")
ObjectPropertyDomain(:contract_suppliedBy :Contract)
ObjectPropertyRange(:contract_suppliedBy :Supplier)

# Contract → Commodity
AnnotationAssertion(rdfs:label :contract_coversCommodity "covers commodity")
ObjectPropertyDomain(:contract_coversCommodity :Contract)
ObjectPropertyRange(:contract_coversCommodity :Commodity)

# ContractScope → Contract
AnnotationAssertion(rdfs:label :scope_ofContract "scope of")
ObjectPropertyDomain(:scope_ofContract :ContractScope)
ObjectPropertyRange(:scope_ofContract :Contract)

# ToleranceException → Invoice
AnnotationAssertion(rdfs:label :exception_onInvoice "exception on")
ObjectPropertyDomain(:exception_onInvoice :ToleranceException)
ObjectPropertyRange(:exception_onInvoice :Invoice)

# ToleranceException → PurchaseOrder
AnnotationAssertion(rdfs:label :exception_againstPO "exception against")
ObjectPropertyDomain(:exception_againstPO :ToleranceException)
ObjectPropertyRange(:exception_againstPO :PurchaseOrder)

# ExceptionRule → Commodity
AnnotationAssertion(rdfs:label :rule_appliesToCommodity "applies to commodity")
ObjectPropertyDomain(:rule_appliesToCommodity :ExceptionRule)
ObjectPropertyRange(:rule_appliesToCommodity :Commodity)

# ExceptionRule → Supplier
AnnotationAssertion(rdfs:label :rule_forSupplier "for supplier")
ObjectPropertyDomain(:rule_forSupplier :ExceptionRule)
ObjectPropertyRange(:rule_forSupplier :Supplier)

# SpendRecord → Invoice
AnnotationAssertion(rdfs:label :spend_fromInvoice "from invoice")
ObjectPropertyDomain(:spend_fromInvoice :SpendRecord)
ObjectPropertyRange(:spend_fromInvoice :Invoice)

# SpendRecord → Supplier
AnnotationAssertion(rdfs:label :spend_withSupplier "with supplier")
ObjectPropertyDomain(:spend_withSupplier :SpendRecord)
ObjectPropertyRange(:spend_withSupplier :Supplier)

# SpendRecord → Commodity
AnnotationAssertion(rdfs:label :spend_forCommodity "for commodity")
ObjectPropertyDomain(:spend_forCommodity :SpendRecord)
ObjectPropertyRange(:spend_forCommodity :Commodity)

# SpendRecord → FXRate
AnnotationAssertion(rdfs:label :spend_convertedWith "converted with")
ObjectPropertyDomain(:spend_convertedWith :SpendRecord)
ObjectPropertyRange(:spend_convertedWith :FXRate)

# Requisition → CostCenter
AnnotationAssertion(rdfs:label :pr_chargedTo "charged to")
ObjectPropertyDomain(:pr_chargedTo :Requisition)
ObjectPropertyRange(:pr_chargedTo :CostCenter)

# Budget → CostCenter
AnnotationAssertion(rdfs:label :budget_forCostCenter "for cost center")
ObjectPropertyDomain(:budget_forCostCenter :Budget)
ObjectPropertyRange(:budget_forCostCenter :CostCenter)


############################
#   Data Properties (domains + ranges)
############################

# Supplier
DataPropertyDomain(:Supplier.supplierId :Supplier)  DataPropertyRange(:Supplier.supplierId xsd:string)
DataPropertyDomain(:Supplier.name :Supplier)         DataPropertyRange(:Supplier.name xsd:string)
DataPropertyDomain(:Supplier.taxId :Supplier)         DataPropertyRange(:Supplier.taxId xsd:string)
DataPropertyDomain(:Supplier.status :Supplier)        DataPropertyRange(:Supplier.status xsd:string)
DataPropertyDomain(:Supplier.parentSupplierId :Supplier) DataPropertyRange(:Supplier.parentSupplierId xsd:string)
DataPropertyDomain(:Supplier.country :Supplier)       DataPropertyRange(:Supplier.country xsd:string)
DataPropertyDomain(:Supplier.preferredFlag :Supplier) DataPropertyRange(:Supplier.preferredFlag xsd:boolean)

# Contract
DataPropertyDomain(:Contract.contractId :Contract)  DataPropertyRange(:Contract.contractId xsd:string)
DataPropertyDomain(:Contract.title :Contract)        DataPropertyRange(:Contract.title xsd:string)
DataPropertyDomain(:Contract.startDate :Contract)    DataPropertyRange(:Contract.startDate xsd:date)
DataPropertyDomain(:Contract.endDate :Contract)      DataPropertyRange(:Contract.endDate xsd:date)
DataPropertyDomain(:Contract.totalValue :Contract)   DataPropertyRange(:Contract.totalValue xsd:decimal)
DataPropertyDomain(:Contract.currency :Contract)     DataPropertyRange(:Contract.currency xsd:string)
DataPropertyDomain(:Contract.status :Contract)       DataPropertyRange(:Contract.status xsd:string)

# ContractScope
DataPropertyDomain(:ContractScope.scopeId :ContractScope)       DataPropertyRange(:ContractScope.scopeId xsd:string)
DataPropertyDomain(:ContractScope.contractId :ContractScope)    DataPropertyRange(:ContractScope.contractId xsd:string)
DataPropertyDomain(:ContractScope.region :ContractScope)        DataPropertyRange(:ContractScope.region xsd:string)
DataPropertyDomain(:ContractScope.legalEntity :ContractScope)   DataPropertyRange(:ContractScope.legalEntity xsd:string)
DataPropertyDomain(:ContractScope.commodityGroup :ContractScope) DataPropertyRange(:ContractScope.commodityGroup xsd:string)
DataPropertyDomain(:ContractScope.validFrom :ContractScope)     DataPropertyRange(:ContractScope.validFrom xsd:date)
DataPropertyDomain(:ContractScope.validTo :ContractScope)       DataPropertyRange(:ContractScope.validTo xsd:date)
DataPropertyDomain(:ContractScope.exclusions :ContractScope)    DataPropertyRange(:ContractScope.exclusions xsd:string)

# Commodity
DataPropertyDomain(:Commodity.commodityId :Commodity)       DataPropertyRange(:Commodity.commodityId xsd:string)
DataPropertyDomain(:Commodity.code :Commodity)               DataPropertyRange(:Commodity.code xsd:string)
DataPropertyDomain(:Commodity.name :Commodity)               DataPropertyRange(:Commodity.name xsd:string)
DataPropertyDomain(:Commodity.level :Commodity)              DataPropertyRange(:Commodity.level xsd:integer)
DataPropertyDomain(:Commodity.parentCommodityId :Commodity) DataPropertyRange(:Commodity.parentCommodityId xsd:string)

# Invoice
DataPropertyDomain(:Invoice.invoiceId :Invoice)    DataPropertyRange(:Invoice.invoiceId xsd:string)
DataPropertyDomain(:Invoice.invoiceDate :Invoice)  DataPropertyRange(:Invoice.invoiceDate xsd:date)
DataPropertyDomain(:Invoice.amount :Invoice)        DataPropertyRange(:Invoice.amount xsd:decimal)
DataPropertyDomain(:Invoice.currency :Invoice)      DataPropertyRange(:Invoice.currency xsd:string)
DataPropertyDomain(:Invoice.status :Invoice)        DataPropertyRange(:Invoice.status xsd:string)
DataPropertyDomain(:Invoice.supplierId :Invoice)    DataPropertyRange(:Invoice.supplierId xsd:string)
DataPropertyDomain(:Invoice.poId :Invoice)          DataPropertyRange(:Invoice.poId xsd:string)

# PurchaseOrder
DataPropertyDomain(:PurchaseOrder.poId :PurchaseOrder)       DataPropertyRange(:PurchaseOrder.poId xsd:string)
DataPropertyDomain(:PurchaseOrder.amount :PurchaseOrder)      DataPropertyRange(:PurchaseOrder.amount xsd:decimal)
DataPropertyDomain(:PurchaseOrder.currency :PurchaseOrder)    DataPropertyRange(:PurchaseOrder.currency xsd:string)
DataPropertyDomain(:PurchaseOrder.status :PurchaseOrder)      DataPropertyRange(:PurchaseOrder.status xsd:string)
DataPropertyDomain(:PurchaseOrder.supplierId :PurchaseOrder)  DataPropertyRange(:PurchaseOrder.supplierId xsd:string)
DataPropertyDomain(:PurchaseOrder.orderDate :PurchaseOrder)   DataPropertyRange(:PurchaseOrder.orderDate xsd:date)

# Item
DataPropertyDomain(:Item.itemId :Item)          DataPropertyRange(:Item.itemId xsd:string)
DataPropertyDomain(:Item.description :Item)      DataPropertyRange(:Item.description xsd:string)
DataPropertyDomain(:Item.quantity :Item)          DataPropertyRange(:Item.quantity xsd:decimal)
DataPropertyDomain(:Item.unitPrice :Item)        DataPropertyRange(:Item.unitPrice xsd:decimal)
DataPropertyDomain(:Item.currency :Item)          DataPropertyRange(:Item.currency xsd:string)
DataPropertyDomain(:Item.commodityId :Item)      DataPropertyRange(:Item.commodityId xsd:string)
DataPropertyDomain(:Item.prId :Item)              DataPropertyRange(:Item.prId xsd:string)
DataPropertyDomain(:Item.poId :Item)              DataPropertyRange(:Item.poId xsd:string)
DataPropertyDomain(:Item.invoiceId :Item)        DataPropertyRange(:Item.invoiceId xsd:string)

# FXRate
DataPropertyDomain(:FXRate.rateId :FXRate)            DataPropertyRange(:FXRate.rateId xsd:string)
DataPropertyDomain(:FXRate.fromCurrency :FXRate)      DataPropertyRange(:FXRate.fromCurrency xsd:string)
DataPropertyDomain(:FXRate.toCurrency :FXRate)        DataPropertyRange(:FXRate.toCurrency xsd:string)
DataPropertyDomain(:FXRate.rate :FXRate)              DataPropertyRange(:FXRate.rate xsd:decimal)
DataPropertyDomain(:FXRate.effectiveDate :FXRate)     DataPropertyRange(:FXRate.effectiveDate xsd:date)

# Requisition
DataPropertyDomain(:Requisition.prId :Requisition)          DataPropertyRange(:Requisition.prId xsd:string)
DataPropertyDomain(:Requisition.description :Requisition)    DataPropertyRange(:Requisition.description xsd:string)
DataPropertyDomain(:Requisition.requester :Requisition)      DataPropertyRange(:Requisition.requester xsd:string)
DataPropertyDomain(:Requisition.location :Requisition)       DataPropertyRange(:Requisition.location xsd:string)
DataPropertyDomain(:Requisition.quantity :Requisition)        DataPropertyRange(:Requisition.quantity xsd:integer)
DataPropertyDomain(:Requisition.costCenterId :Requisition)   DataPropertyRange(:Requisition.costCenterId xsd:string)
DataPropertyDomain(:Requisition.status :Requisition)         DataPropertyRange(:Requisition.status xsd:string)

# CostCenter
DataPropertyDomain(:CostCenter.costCenterId :CostCenter)  DataPropertyRange(:CostCenter.costCenterId xsd:string)
DataPropertyDomain(:CostCenter.name :CostCenter)           DataPropertyRange(:CostCenter.name xsd:string)
DataPropertyDomain(:CostCenter.department :CostCenter)     DataPropertyRange(:CostCenter.department xsd:string)
DataPropertyDomain(:CostCenter.region :CostCenter)         DataPropertyRange(:CostCenter.region xsd:string)

# Budget
DataPropertyDomain(:Budget.budgetId :Budget)          DataPropertyRange(:Budget.budgetId xsd:string)
DataPropertyDomain(:Budget.costCenterId :Budget)      DataPropertyRange(:Budget.costCenterId xsd:string)
DataPropertyDomain(:Budget.period :Budget)             DataPropertyRange(:Budget.period xsd:string)
DataPropertyDomain(:Budget.allocatedAmount :Budget)   DataPropertyRange(:Budget.allocatedAmount xsd:decimal)
DataPropertyDomain(:Budget.currency :Budget)           DataPropertyRange(:Budget.currency xsd:string)

# ToleranceException
DataPropertyDomain(:ToleranceException.exceptionId :ToleranceException)  DataPropertyRange(:ToleranceException.exceptionId xsd:string)
DataPropertyDomain(:ToleranceException.invoiceId :ToleranceException)    DataPropertyRange(:ToleranceException.invoiceId xsd:string)
DataPropertyDomain(:ToleranceException.poId :ToleranceException)          DataPropertyRange(:ToleranceException.poId xsd:string)
DataPropertyDomain(:ToleranceException.exceptionType :ToleranceException) DataPropertyRange(:ToleranceException.exceptionType xsd:string)
DataPropertyDomain(:ToleranceException.thresholdPct :ToleranceException) DataPropertyRange(:ToleranceException.thresholdPct xsd:decimal)
DataPropertyDomain(:ToleranceException.actualPct :ToleranceException)    DataPropertyRange(:ToleranceException.actualPct xsd:decimal)
DataPropertyDomain(:ToleranceException.status :ToleranceException)       DataPropertyRange(:ToleranceException.status xsd:string)

# ExceptionRule
DataPropertyDomain(:ExceptionRule.ruleId :ExceptionRule)       DataPropertyRange(:ExceptionRule.ruleId xsd:string)
DataPropertyDomain(:ExceptionRule.commodityId :ExceptionRule)  DataPropertyRange(:ExceptionRule.commodityId xsd:string)
DataPropertyDomain(:ExceptionRule.supplierId :ExceptionRule)   DataPropertyRange(:ExceptionRule.supplierId xsd:string)
DataPropertyDomain(:ExceptionRule.condition :ExceptionRule)     DataPropertyRange(:ExceptionRule.condition xsd:string)
DataPropertyDomain(:ExceptionRule.resolution :ExceptionRule)   DataPropertyRange(:ExceptionRule.resolution xsd:string)
DataPropertyDomain(:ExceptionRule.approvedBy :ExceptionRule)   DataPropertyRange(:ExceptionRule.approvedBy xsd:string)
DataPropertyDomain(:ExceptionRule.createdDate :ExceptionRule)  DataPropertyRange(:ExceptionRule.createdDate xsd:date)

# SpendRecord
DataPropertyDomain(:SpendRecord.spendId :SpendRecord)            DataPropertyRange(:SpendRecord.spendId xsd:string)
DataPropertyDomain(:SpendRecord.invoiceId :SpendRecord)          DataPropertyRange(:SpendRecord.invoiceId xsd:string)
DataPropertyDomain(:SpendRecord.supplierId :SpendRecord)         DataPropertyRange(:SpendRecord.supplierId xsd:string)
DataPropertyDomain(:SpendRecord.commodityId :SpendRecord)        DataPropertyRange(:SpendRecord.commodityId xsd:string)
DataPropertyDomain(:SpendRecord.rateId :SpendRecord)             DataPropertyRange(:SpendRecord.rateId xsd:string)
DataPropertyDomain(:SpendRecord.originalAmount :SpendRecord)     DataPropertyRange(:SpendRecord.originalAmount xsd:decimal)
DataPropertyDomain(:SpendRecord.originalCurrency :SpendRecord)   DataPropertyRange(:SpendRecord.originalCurrency xsd:string)
DataPropertyDomain(:SpendRecord.normalizedAmount :SpendRecord)   DataPropertyRange(:SpendRecord.normalizedAmount xsd:decimal)
DataPropertyDomain(:SpendRecord.period :SpendRecord)             DataPropertyRange(:SpendRecord.period xsd:string)
DataPropertyDomain(:SpendRecord.onContract :SpendRecord)         DataPropertyRange(:SpendRecord.onContract xsd:boolean)


############################
#   Class Annotations
############################

AnnotationAssertion(rdfs:label :Supplier "Supplier")
AnnotationAssertion(rdfs:label :Contract "Contract")
AnnotationAssertion(rdfs:label :ContractScope "Contract Scope")
AnnotationAssertion(rdfs:label :Commodity "Commodity")
AnnotationAssertion(rdfs:label :Invoice "Invoice")
AnnotationAssertion(rdfs:label :PurchaseOrder "Purchase Order")
AnnotationAssertion(rdfs:label :Item "Line Item")
AnnotationAssertion(rdfs:label :FXRate "FX Rate")
AnnotationAssertion(rdfs:label :Requisition "Purchase Requisition")
AnnotationAssertion(rdfs:label :CostCenter "Cost Center")
AnnotationAssertion(rdfs:label :Budget "Budget")
AnnotationAssertion(rdfs:label :ToleranceException "Tolerance Exception")
AnnotationAssertion(rdfs:label :ExceptionRule "Exception Rule")
AnnotationAssertion(rdfs:label :SpendRecord "Spend Record")

)
