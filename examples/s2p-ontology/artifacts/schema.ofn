Declaration(DataProperty(:ToleranceException.exceptionId))
Declaration(DataProperty(:ToleranceException.invoiceId))
Declaration(DataProperty(:ToleranceException.poId))
Declaration(DataProperty(:ToleranceException.exceptionType))
Declaration(DataProperty(:ToleranceException.thresholdPct))
Declaration(DataProperty(:ToleranceException.actualPct))
