Prefix(:=<https://ontology.uipath.com/s2p#>)
Prefix(owl:=<http://www.w3.org/2002/07/owl#>)
Prefix(rdf:=<http://www.w3.org/1999/02/22-rdf-syntax-ns#>)
Prefix(xml:=<http://www.w3.org/XML/1998/namespace>)
Prefix(xsd:=<http://www.w3.org/2001/XMLSchema#>)
Prefix(rdfs:=<http://www.w3.org/2000/01/rdf-schema#>)


Ontology(<https://ontology.uipath.com/s2p>

############################
#   Class Declarations
############################

Declaration(Class(:Supplier))
Declaration(Class(:Contract))
Declaration(Class(:ContractScope))
Declaration(Class(:Commodity))
Declaration(Class(:Invoice))
Declaration(Class(:PurchaseOrder))
Declaration(Class(:Item))
Declaration(Class(:FXRate))
Declaration(Class(:Requisition))
Declaration(Class(:CostCenter))
Declaration(Class(:Budget))
Declaration(Class(:ToleranceException))
Declaration(Class(:ExceptionRule))
Declaration(Class(:SpendRecord))

############################
#   Object Property Declarations
############################

Declaration(ObjectProperty(:supplier_hasParent))
Declaration(ObjectProperty(:commodity_partOf))
Declaration(ObjectProperty(:invoice_paidTo))
Declaration(ObjectProperty(:invoice_referencesPO))
Declaration(ObjectProperty(:po_orderedFrom))
Declaration(ObjectProperty(:item_classifiedAs))
Declaration(ObjectProperty(:item_onRequisition))
Declaration(ObjectProperty(:item_onPO))
Declaration(ObjectProperty(:item_onInvoice))
Declaration(ObjectProperty(:contract_suppliedBy))
Declaration(ObjectProperty(:contract_coversCommodity))
Declaration(ObjectProperty(:scope_ofContract))
Declaration(ObjectProperty(:exception_onInvoice))
Declaration(ObjectProperty(:exception_againstPO))
Declaration(ObjectProperty(:rule_appliesToCommodity))
Declaration(ObjectProperty(:rule_forSupplier))
Declaration(ObjectProperty(:spend_fromInvoice))
Declaration(ObjectProperty(:spend_withSupplier))
Declaration(ObjectProperty(:spend_forCommodity))
Declaration(ObjectProperty(:spend_convertedWith))
Declaration(ObjectProperty(:pr_chargedTo))
Declaration(ObjectProperty(:budget_forCostCenter))

############################
#   Data Property Declarations
############################

# Supplier
Declaration(DataProperty(:Supplier.supplierId))
Declaration(DataProperty(:Supplier.name))
Declaration(DataProperty(:Supplier.taxId))
Declaration(DataProperty(:Supplier.status))
Declaration(DataProperty(:Supplier.parentSupplierId))
Declaration(DataProperty(:Supplier.country))
Declaration(DataProperty(:Supplier.preferredFlag))

# Contract
Declaration(DataProperty(:Contract.contractId))
Declaration(DataProperty(:Contract.title))
Declaration(DataProperty(:Contract.startDate))
Declaration(DataProperty(:Contract.endDate))
Declaration(DataProperty(:Contract.totalValue))
Declaration(DataProperty(:Contract.currency))
Declaration(DataProperty(:Contract.status))

# ContractScope
Declaration(DataProperty(:ContractScope.scopeId))
Declaration(DataProperty(:ContractScope.contractId))
Declaration(DataProperty(:ContractScope.region))
Declaration(DataProperty(:ContractScope.legalEntity))
Declaration(DataProperty(:ContractScope.commodityGroup))
Declaration(DataProperty(:ContractScope.validFrom))
Declaration(DataProperty(:ContractScope.validTo))
Declaration(DataProperty(:ContractScope.exclusions))

# Commodity
Declaration(DataProperty(:Commodity.commodityId))
Declaration(DataProperty(:Commodity.code))
Declaration(DataProperty(:Commodity.name))
Declaration(DataProperty(:Commodity.level))
Declaration(DataProperty(:Commodity.parentCommodityId))

# Invoice
Declaration(DataProperty(:Invoice.invoiceId))
Declaration(DataProperty(:Invoice.invoiceDate))
Declaration(DataProperty(:Invoice.amount))
Declaration(DataProperty(:Invoice.currency))
Declaration(DataProperty(:Invoice.status))
Declaration(DataProperty(:Invoice.supplierId))
Declaration(DataProperty(:Invoice.poId))

# PurchaseOrder
Declaration(DataProperty(:PurchaseOrder.poId))
Declaration(DataProperty(:PurchaseOrder.amount))
Declaration(DataProperty(:PurchaseOrder.currency))
Declaration(DataProperty(:PurchaseOrder.status))
Declaration(DataProperty(:PurchaseOrder.supplierId))
Declaration(DataProperty(:PurchaseOrder.orderDate))

# Item
Declaration(DataProperty(:Item.itemId))
Declaration(DataProperty(:Item.description))
Declaration(DataProperty(:Item.quantity))
Declaration(DataProperty(:Item.unitPrice))
Declaration(DataProperty(:Item.currency))
Declaration(DataProperty(:Item.commodityId))
Declaration(DataProperty(:Item.prId))
Declaration(DataProperty(:Item.poId))
Declaration(DataProperty(:Item.invoiceId))

# FXRate
Declaration(DataProperty(:FXRate.rateId))
Declaration(DataProperty(:FXRate.fromCurrency))
Declaration(DataProperty(:FXRate.toCurrency))
Declaration(DataProperty(:FXRate.rate))
Declaration(DataProperty(:FXRate.effectiveDate))

# Requisition
Declaration(DataProperty(:Requisition.prId))
Declaration(DataProperty(:Requisition.description))
Declaration(DataProperty(:Requisition.requester))
Declaration(DataProperty(:Requisition.location))
Declaration(DataProperty(:Requisition.quantity))
Declaration(DataProperty(:Requisition.costCenterId))
Declaration(DataProperty(:Requisition.status))

# CostCenter
Declaration(DataProperty(:CostCenter.costCenterId))
Declaration(DataProperty(:CostCenter.name))
Declaration(DataProperty(:CostCenter.department))
Declaration(DataProperty(:CostCenter.region))

# Budget
Declaration(DataProperty(:Budget.budgetId))
Declaration(DataProperty(:Budget.costCenterId))
Declaration(DataProperty(:Budget.period))
Declaration(DataProperty(:Budget.allocatedAmount))
Declaration(DataProperty(:Budget.currency))

