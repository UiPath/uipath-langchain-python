name: Integration testing

on:
  push:
    branches: [ main, develop ]
  pull_request:
    branches: [ main ]

jobs:
  integration-tests:
    runs-on: ubuntu-latest
    permissions:
      contents: read
      pull-requests: write

    strategy:
      matrix:
        include:
          - build-dir: company-research-agent
            use-azure-chat: "true"
          - build-dir: company-research-agent
            use-azure-chat: "false"
          - build-dir: simple-local-mcp
            use-azure-chat: "true"
          - build-dir: simple-local-mcp
            use-azure-chat: "false"
          - build-dir: ticket-classification
            use-azure-chat: "true"
          - build-dir: ticket-classification
            use-azure-chat: "false"
          - build-dir: multi-agent-supervisor-researcher-coder
            use-azure-chat: "true"
          - build-dir: multi-agent-supervisor-researcher-coder
            use-azure-chat: "false"

    steps:
    - name: Checkout code
      uses: actions/checkout@v4

    - name: Set up Docker Buildx
      uses: docker/setup-buildx-action@v3

    - name: Build Docker image (${{ matrix.build-dir }}, USE_AZURE_CHAT=${{ matrix.use-azure-chat }})
      run: |
        docker build -f testcases/${{ matrix.build-dir }}/Dockerfile \
          -t ${{ matrix.build-dir }}:test \
          --build-arg CLIENT_ID="${{ secrets.ALPHA_TEST_CLIENT_ID }}" \
          --build-arg CLIENT_SECRET="${{ secrets.ALPHA_TEST_CLIENT_SECRET }}" \
          --build-arg BASE_URL="${{ secrets.ALPHA_BASE_URL }}" \
          --build-arg USE_AZURE_CHAT="${{ matrix.use-azure-chat }}" \
          .